package com.example.project;

import org.junit.Test;
import static org.junit.Assert.assertEquals;

// 1. Target Class to be tested (non-public so it can reside in the same file)
class Calculator {
    public int add(int a, int b) {
        return a + b;
    }
}

// 2. Main JUnit Test Class
public class CalculatorTest {

    @Test
    public void testAdd() {
        // Arrange: Instantiate the class under test
        Calculator calculator = new Calculator();

        // Act: Execute the method being tested
        int actualResult = calculator.add(5, 3);

        // Assert: Verify that the actual output matches the expected output
        assertEquals("The addition result should be 8", 8, actualResult);
    }
}