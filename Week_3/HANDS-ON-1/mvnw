if [ -z "$MAVEN_HOME" ] ; then
  PRG="$0"
  while [ -h "$PRG" ] ; do
    ls=`ls -ld "$PRG"`
    link=`expr "$ls" : '.*-> \(.*\)$'`
    if expr "$link" : '/.*' > /dev/null; then
      PRG="$link"
    else
      PRG=`dirname "$PRG"`"/$link"
    fi
  done
  saveddir=`pwd`
  MAVEN_HOME=`dirname "$PRG"`/..
  MAVEN_HOME=`cd "$MAVEN_HOME" && pwd`
  export MAVEN_HOME
  cd "$saveddir"
fi

if [ -z "$JAVA_HOME" ] ; then
  javaExecutable="`which java`"
  if [ -z "$javaExecutable" ] ; then
    echo "Error: JAVA_HOME is not defined correctly."
    echo "  We cannot execute $javaExecutable"
    exit 1
  fi
  if [ ! -x "$javaExecutable" ] ; then
    echo "Error: $JAVA_HOME/bin/java exists but is not executable."
    echo "  Changing permissions now"
    chmod +x "$javaExecutable"
  fi
  JAVA_HOME="`dirname $javaExecutable`/.."
  export JAVA_HOME
fi

exec "$MAVEN_HOME"/bin/mvn "$@"
